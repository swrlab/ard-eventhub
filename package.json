{
	"name": "ard-eventhub",
	"version": "2.3.2",
	"description": "ARD system to distribute real-time (live) metadata for primarily radio broadcasts.",
	"main": "./src/ingest/index.ts",
	"imports": {
		"#config": "./src/config.ts",
		"#env": "./src/env.ts",
		"#types": "./src/types/index.ts"
	},
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=10.0.0",
		"bun": ">= 1.0.0"
	},
	"scripts": {
		"check": "biome check",
		"check:fix": "biome check --write",
		"docs:serve": "docsify serve . --port 3000",
		"coreId": "bun run ./src/cli/core-id.ts",
		"feed": "bun run ./src/cli/feed.ts",
		"format": "biome format --write",
		"format:check": "biome format",
		"ingest": "bun run --hot ./src/ingest/index.ts",
		"test": "bun test --timeout 120000",
		"lint": "biome lint",
		"lint:fix": "biome lint --write --unsafe",
		"typecheck": "tsgo",
		"knip": "knip",
		"docker:build": "docker build . -t swr/ard-eventhub",
		"docker:run": "docker run --env-file .env -p 8080:8080 --name ard-eventhub swr/ard-eventhub",
		"docker:scan": "bun docker:build && docker scout quickview",
		"docker:clean": "docker rm ard-eventhub",
		"openapi:format": "bunx biome format openapi.json --write && bunx prettier openapi.yaml -w",
		"license": "bunx license-compliance -f json -r detailed"
	},
	"keywords": [
		"ard",
		"metadata",
		"pubsub"
	],
	"author": "SWR Audio Lab <lab@swr.de>",
	"license": "EUPL-1.2",
	"dependencies": {
		"@frytg/check-required-env": "npm:@jsr/frytg__check-required-env",
		"@frytg/dates": "npm:@jsr/frytg__dates",
		"@frytg/logger": "npm:@jsr/frytg__logger",
		"@google-cloud/datastore": "^10.1.0",
		"@google-cloud/pubsub": "^5.2.3",
		"@swrlab/utils": "^2.2.0",
		"@types/supertest": "^6.0.3",
		"compression": "^1.8.1",
		"dd-trace": "^5.86.0",
		"express": "^4.22.1",
		"express-openapi-validator": "^5.6.2",
		"firebase-admin": "^13.6.1",
		"google-auth-library": "^10.5.0",
		"jsonwebtoken": "^9.0.3",
		"slug": "^11.0.1",
		"supertest": "^7.2.2",
		"swagger-ui-express": "^5.0.1",
		"typescript": "^5.9.3",
		"ulid": "^3.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@swrlab/style-guide": "^2.1.2",
		"@types/bun": "^1.3.9",
		"@types/compression": "^1.8.1",
		"@types/dd-trace": "^0.9.3",
		"@types/express": "^5.0.6",
		"@types/node": "^25.3.2",
		"@types/slug": "^5.0.9",
		"@types/swagger-ui-express": "^4.1.8",
		"@typescript/native-preview": "^7.0.0-dev.20260227.1",
		"docsify-cli": "^4.4.4",
		"knip": "^5.85.0",
		"license-compliance": "^3.0.1",
		"prettier": "^3.8.1"
	},
	"resolutions": {
		"ansi-regex": "^5.0.1",
		"got": "^11.8.6",
		"strip-ansi": "^6.0.1",
		"update-notifier": "^5.1.0"
	},
	"type": "module",
	"prettier": "@swrlab/style-guide/prettier"
}
